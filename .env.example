# --- Server (Vercel / local dev API) — NEVER commit real keys ---
OPENAI_API_KEY=
# Optional: chat + style classify (default gpt-5.4)
# OPENAI_MODEL=gpt-5.4
# Critique only (optional; overrides OPENAI_MODEL for /api/critique)
# OPENAI_CRITIQUE_MODEL=gpt-5.4
# Stage-specific critique models (optional; each falls back to OPENAI_CRITIQUE_MODEL, then OPENAI_MODEL)
# OPENAI_MODEL_CLASSIFY=gpt-5.4
# OPENAI_MODEL_EVIDENCE=gpt-5.4
# OPENAI_MODEL_CALIBRATION=gpt-5.4
# OPENAI_MODEL_WRITE=gpt-5.4
# OPENAI_MODEL_VALIDATE=gpt-5.4
# OPENAI_MODEL_FALLBACK=gpt-5.4
# OPENAI_MODEL_CLARITY=gpt-5.4

# Image edit preview (Phase 1) — default gpt-image-1.5; quality defaults to high (medium/low to save cost)
# OPENAI_IMAGE_EDIT_MODEL=gpt-image-1.5
# OPENAI_IMAGE_EDIT_QUALITY=high

# Optional: Stripe pay-per-use ($1.49 / critique, $0.99 / AI preview). When all three are set, paid routes require checkout.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_CHECKOUT_JWT_SECRET=  # random 32+ chars; signs short-lived tokens after Checkout
# STRIPE_CHECKOUT_ORIGIN=https://your-app.vercel.app  # public site URL (no trailing slash); required for checkout-return redirect

# --- Frontend (Vite) — safe to expose ---
# GitHub project Pages build: must match the URL path, e.g. /ArtVision-Pro/
# (The included GitHub Action sets this from the repo name.)
# VITE_BASE=/

# Production API origin (no trailing slash), e.g. https://your-api.vercel.app
# Required on GitHub Pages for OpenAI critique (Pages has no serverless API).
# VITE_CRITIQUE_API_URL=

# Local dev: `npm run dev` starts API + Vite (full mode). Use `npm run dev:ui` for Vite only.
